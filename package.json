{
  "name": "atpdashboard",
  "private": true,
  "version": "1.3.8",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "overrides": {
      "object-path": ">=0.11.8"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "update": "pnpm dlx npm-check-updates && pnpm install",
    "preview": "vite preview",
    "update:publicsuffix": "curl -s https://publicsuffix.org/list/public_suffix_list.dat | grep -vE '(^//|^$)' | grep -v '^$' | jq -R -s 'split(\"\\n\") | map(select(. != \"\"))' > src/data/publicSuffixList.json"
  },
  "author": {
    "name": "ATP Dashboard",
    "url": "https://atpdashboard.usounds.work/"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@react-spring/web": "^10.0.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@uiw/react-json-view": "2.0.0-alpha.41",
    "apexcharts": "^5.10.3",
    "braces": "^3.0.3",
    "did-resolver": "^4.1.0",
    "flatpickr": "^4.6.13",
    "headlessui": "^0.0.0",
    "jsvectormap": "^1.7.0",
    "match-sorter": "^8.2.0",
    "pretty-print-json": "^3.0.7",
    "react": "^19.2.4",
    "react-apexcharts": "^2.1.0",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1",
    "react-spinners": "^0.17.0",
    "react-toastify": "^11.0.5",
    "rollup": "~4.59.0",
    "sort-by": "^1.2.0",
    "web-did-resolver": "^2.0.32",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.27.4",
    "file-loader": "^6.2.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.0",
    "webpack": "~5.105.4"
  }
}